{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "target": "ES2022"
  },
  "include": ["electron-vite.config.*", "src/main/**/*", "src/preload/**/*"]
}
